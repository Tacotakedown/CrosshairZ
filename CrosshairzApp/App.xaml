<Application
    x:Class="CrosshairZ.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#FF0E1014" />
        <SolidColorBrush x:Key="PanelBrush" Color="#CC171B22" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#FF2B313C" />
        <SolidColorBrush x:Key="AccentBrush" Color="#FF53D4FF" />
        <SolidColorBrush x:Key="SubtleBrush" Color="#FF9AA4B2" />
    </Application.Resources>
</Application>